//******************************************************************************************************************
// FUNCTION SETUP IOs
//******************************************************************************************************************

void ios_setup(void) {

  pinMode(BTN1,INPUT_PULLUP);
  pinMode(BTN2,INPUT_PULLUP);

  pinMode(LED1,OUTPUT);
  pinMode(LED2,OUTPUT);

  digitalWrite(LED1,LOW);
  digitalWrite(LED2,LOW);
   
}

